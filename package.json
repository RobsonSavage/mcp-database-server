{
    "name": "@robsonsavage/database-server",
    "version": "2.1.0",
    "description": "MCP server for SQLite, SQL Server, PostgreSQL and MySQL. Fork of @executeautomation/database-server with Windows integrated auth and multi-connection routing.",
    "license": "MIT",
    "author": "RobsonSavage (fork) — original by ExecuteAutomation, Ltd",
    "homepage": "https://github.com/RobsonSavage/mcp-database-server",
    "bugs": "https://github.com/RobsonSavage/mcp-database-server/issues",
    "type": "module",
    "bin": {
        "rs-database-server": "dist/src/index.js",
        "ea-database-server": "dist/src/index.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc && shx cp package.json dist/ && shx chmod +x dist/src/index.js",
        "prepare": "npm run build",
        "watch": "tsc --watch",
        "start": "node dist/src/index.js",
        "dev": "tsc && node dist/src/index.js",
        "example": "node examples/example.js",
        "clean": "rimraf dist",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@aws-sdk/rds-signer": "^3.0.0",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "mssql": "11.0.1",
        "mysql2": "^3.14.1",
        "pg": "^8.11.3",
        "sqlite3": "^6.0.1"
    },
    "optionalDependencies": {
        "msnodesqlv8": "^4.4.0"
    },
    "devDependencies": {
        "@types/mssql": "^9.1.5",
        "@types/pg": "^8.11.13",
        "rimraf": "^6.1.3",
        "shx": "0.4.0",
        "typescript": "5.8.3",
        "vitest": "^4.1.4"
    }
}
