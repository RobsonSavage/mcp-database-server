{
  "servers": {
    "RS-SQL01": {
      "trustServerCertificate": true,
      "connectionTimeoutMs": 15000,
      "multipleActiveResultSets": true,
      "databases": {
        "QMaster": {
          "default": true,
          "logins": {
            "readonly": {
              "default": true,
              "user": "${env:RS_SQL01_READONLY_USER}",
              "password": "${env:RS_SQL01_READONLY_PASSWORD}"
            },
            "QMaster": {
              "user": "${env:RS_SQL01_QMASTER_USER}",
              "password": "${env:RS_SQL01_QMASTER_PASSWORD}"
            }
          }
        },
        "BugTracker": {
          "logins": {
            "readonly": {
              "default": true,
              "user": "${env:RS_SQL01_READONLY_USER}",
              "password": "${env:RS_SQL01_READONLY_PASSWORD}"
            },
            "BugTracker": {
              "user": "${env:RS_SQL01_BUGTRACKER_USER}",
              "password": "${env:RS_SQL01_BUGTRACKER_PASSWORD}"
            }
          }
        }
      }
    },
    "localhost": {
      "default": true,
      "trustServerCertificate": true,
      "connectionTimeoutMs": 15000,
      "multipleActiveResultSets": true,
      "allowDdl": true,
      "driver": "ODBC Driver 18 for SQL Server",
      "databases": {
        "x26QMaster": {
          "logins": {
            "windows-auth": {
              "trustedConnection": true
            }
          }
        }
      }
    }
  }
}
